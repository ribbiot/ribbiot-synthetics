# ------------------------------------------------------------------------------
# Example tfvars for dev. Copy to terraform.tfvars and fill in (do not commit tfvars).
# Or use environment variables: export TF_VAR_dd_api_key=... TF_VAR_dd_app_key=...
# ------------------------------------------------------------------------------

# dd_api_key  = "your-datadog-api-key"
# dd_app_key  = "your-datadog-app-key"
dd_api_url = "https://api.datadoghq.com"

# Framework default: 3 geos, every 2 hours (7200s). Omit to use variable defaults.
# default_locations = ["aws:us-east-1", "aws:us-west-2", "gcp:us-west1"]
# default_frequency = 7200

example_health_url   = "https://httpbin.org/get"
example_test_status  = "live"
