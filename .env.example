# Copy to .env and fill in (do not commit .env).
# Load before Terraform:  set -a && source .env && set +a
# Then run from environments/dev:  terraform plan

# Datadog (from Organization Settings → API Keys / Application Keys)
# TF_VAR_dd_api_key=
# TF_VAR_dd_app_key=

# Optional: Datadog site (default in dev is US5)
# c=https://api.us5.datadoghq.com
# DD_API_URL=https://api.datadoghq.com   # US1
# DD_API_URL=https://api.datadoghq.eu     # EU

# Multi-step Auth0 + GraphQL test (dev). Never commit real values.
# Use raw values here (no URL encoding). They are encoded when building the Auth0 request.
# TF_VAR_dev_username=chris.atkinson.qa+datadog@gmail.com
# TF_VAR_dev_password=welcome2security!
# TF_VAR_dev_client_secret=

# New-branch script: fetch Linear issue title for initial commit (optional).
# Get from Linear → Settings → API → Personal API keys.
# LINEAR_API_KEY=

# ---------------------------------------------------------------------------
# Apollo MCP Server (DEV ONLY — for Cursor: schema introspection + GraphQL)
# See docs/apollo-mcp-cursor.md and docs/dev-only-scope.md. Do not use for prod.
# ---------------------------------------------------------------------------
# GraphQL endpoint the MCP server talks to (default: dev router only).
# APOLLO_GRAPHQL_ENDPOINT=https://ribbiot-router-dev.up.railway.app/graphql
#
# Authenticated MCP (same Auth0 as dev synthetics): use npm run mcp:start:auth.
# Requires TF_VAR_dev_username, TF_VAR_dev_password, TF_VAR_dev_client_secret
# (same as multi-step GraphQL synthetics). Optional: TF_VAR_dev_auth0_domain.
#
# Optional: target a federated subgraph/supergraph schema (run npm run mcp:select-schema first).
# Rover must be installed and logged in. See docs/apollo-mcp-cursor.md.
# APOLLO_KEY=
# APOLLO_GRAPH_REF=Ribbiot-Serverless@dev-current
